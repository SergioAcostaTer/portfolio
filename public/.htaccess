# Enable rewrite engine
RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://sergioaco.com/$1 [R=301,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.sergioaco\.com [NC]
RewriteRule ^(.*)$ https://sergioaco.com/$1 [R=301,L]

# Rewrite /blog to /blog.html
RewriteRule ^blog/?$ /blog.html [L]

# Rewrite blog posts (e.g., /blog/my-post -> /blog/my-post.html)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Remove .html from URLs in browser
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9} \S+\.html
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Set default charset
AddDefaultCharset UTF-8

# Disable directory listing
Options -Indexes

# Protect .htaccess
<Files ".ht*">
    Require all denied
</Files>

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresDefault "access plus 2 days"
</IfModule>

# Basic security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
